{
  "name": "@opencode-compat/adapter",
  "version": "0.1.3",
  "description": "Universal OCP host adapter — autodetection HostProfile, one runtime for all cooperating hosts",
  "type": "module",
  "license": "MPL-2.0",
  "author": "oakimov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oakimov/opencode-plugin-compat.git",
    "directory": "packages/adapter"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "prepack": "bunx tsc -p tsconfig.json"
  },
  "dependencies": {
    "@opencode-compat/host-promise-v2": "workspace:*",
    "@opencode-compat/profile": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "bugs": {
    "url": "https://github.com/oakimov/opencode-plugin-compat/issues"
  },
  "homepage": "https://github.com/oakimov/opencode-plugin-compat/tree/main/packages/adapter#readme",
  "keywords": [
    "opencode",
    "ocp",
    "adapter",
    "compatibility"
  ],
  "engines": {
    "bun": ">=1.2.0"
  }
}
