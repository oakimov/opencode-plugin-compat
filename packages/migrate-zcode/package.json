{
  "name": "@opencode-compat/migrate-zcode",
  "version": "0.1.0",
  "description": "Companion: migrate plugin-packaged skills/commands/marketplace manifests into a .zcode-plugin tree (not OCP ABI; ZCode stays T0; no host MCP migration)",
  "type": "module",
  "license": "MPL-2.0",
  "author": "oakimov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oakimov/opencode-plugin-compat.git",
    "directory": "packages/migrate-zcode"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}